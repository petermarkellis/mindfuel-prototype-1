  "version": "1.0.0",
  "author": "Peter Ellis",
  "keywords": [
    "react",
    "reactflow",
    "neon",
    "tailwind",
    "node-graph",
    "visualization",
    "prototype",
    "mindfuel"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/petermarkellis/mindfuel-prototype-1.git"
  },
  "homepage": "https://github.com/petermarkellis/mindfuel-prototype-1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:local": "node local-api.js",
