    "@tailwindcss/cli": "^4.1.10",
    "@tailwindcss/postcss": "^4.1.10",
    "@vercel/analytics": "^1.5.0",
    "@vercel/speed-insights": "^1.2.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "html2canvas": "^1.4.1",
    "lineicons": "^1.3.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "reactflow": "^11.11.1",
    "styled-components": "^6.1.8",
